    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "list:visas": "ts-node scripts/list-visas.ts",
    "prepare": "husky install",
    "postinstall": "prisma generate",
    "seed:vietnam": "node scripts/seed-vietnam.js",
    "seed:urgency": "node scripts/seed-urgency.js",
    "seed:insurance": "node scripts/seed-insurance.js",
    "seed:addons": "node scripts/seed-urgency.js && node scripts/seed-insurance.js",
    "indexnow": "node scripts/submit-indexnow.js"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@mdx-js/loader": "^3.1.0",
    "@mdx-js/react": "^3.1.0",
    "@next/mdx": "^15.3.3",
    "@prisma/client": "^6.10.1",
    "@stripe/react-stripe-js": "^3.7.0",
    "@stripe/stripe-js": "^7.3.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "bcryptjs": "^3.0.2",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "isomorphic-dompurify": "^2.25.0",
    "jsonwebtoken": "^9.0.2",
    "lottie-react": "^2.4.1",
    "next": "15.3.8",
    "next-mdx-remote": "^6.0.0",
    "prisma": "^6.10.1",
    "pusher-js": "^8.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "react-phone-input-2": "^2.15.1",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "resend": "^4.6.0",
    "stripe": "^18.2.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "15.3.3",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "prisma": {
    "seed": "node scripts/seed-vietnam.js"
  }
}
